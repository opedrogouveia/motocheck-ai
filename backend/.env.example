# ==========================================================
#  MotoCheck AI — Backend (NestJS) — exemplo de variáveis
#  Copie para `.env` e preencha. NUNCA versione o .env real.
# ==========================================================

# --- Banco de dados (Supabase / PostgreSQL) ---
# Connection pooling (uso normal da aplicação)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?pgbouncer=true"
# Conexão direta (usada nas migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Aplicação ---
PORT=3001
# Origem do frontend liberada no CORS
CORS_ORIGIN="http://localhost:3000"

# --- Autenticação (JWT) ---
# Gere um valor longo e aleatório (ex.: `openssl rand -base64 48`)
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="7d"

# --- Provedor de IA (Google Gemini) ---
# Chave da API: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
