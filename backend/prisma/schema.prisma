generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}
// Tabela de Usuários (Preparada para Auth)
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   // Aqui vai o hash da senha (nunca a senha em texto puro)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamento: Um usuário possui várias análises (TCC)
  analyses  Analysis[]

  @@map("users") // Boa prática: cria a tabela com nome no plural minúsculo no banco
}

// Tabela de Análises (O Core do MotoCheck AI)
model Analysis {
  id              String   @id @default(uuid())
  adText          String   @db.Text
  riskLevel       String   // "LOW", "MEDIUM", "HIGH"
  suspiciousTerms String[] 
  questionsToAsk  String[] 
  createdAt       DateTime @default(now())

  // Relacionamento com o usuário que fez a análise
  userId          String
  user            User     @relation(fields: [userId], references: [id])

  @@map("analyses")
}