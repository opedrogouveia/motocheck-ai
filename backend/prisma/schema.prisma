generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyses  Analysis[]

  @@map("users") 
}

model Analysis {
  id              String   @id @default(uuid())
  adText          String   @db.Text
  riskLevel       String   
  suspiciousTerms String[] 
  questionsToAsk  String[] 
  createdAt       DateTime @default(now())

  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  tags            Tag[]    

  @@map("analyses")
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  
  analyses  Analysis[] 

  @@map("tags")
}